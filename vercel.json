{
  "headers": [
    {
      "source": "/console",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/console/:path*",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.tdpaint.com"
        }
      ],
      "destination": "https://tdpaint.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "tdpaintcell.com"
        }
      ],
      "destination": "https://tdpaint.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.tdpaintcell.com"
        }
      ],
      "destination": "https://tdpaint.com/:path*",
      "permanent": true
    },
    {
      "source": "/about",
      "destination": "/en/about",
      "permanent": true
    },
    {
      "source": "/applications",
      "destination": "/en/applications",
      "permanent": true
